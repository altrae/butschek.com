# Root dependencies and package manager
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# Logs and temporary files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.tmp
*.tmp.*
*.sw[mnpcod]
*~

# Local environment files
.env
.env.*
!.env.example

# Editor and IDE metadata
.idea/
.history/

# VS Code: keep shared workspace settings in git
!.vscode/
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# Common build/test outputs
dist/
coverage/
*.tsbuildinfo

# OS-generated files
.DS_Store
Thumbs.db

# Package-scoped rules (can move to package-level .gitignore files)

# Angular (packages/angular)
packages/angular/.angular/cache/
packages/angular/.sass-cache/
packages/angular/tmp/
packages/angular/out-tsc/
packages/angular/bazel-out/
packages/angular/connect.lock
packages/angular/typings/

# React / Next.js (packages/react)
packages/react/.next/
packages/react/out/
packages/react/build/
packages/react/.vercel/

# Stencil (packages/stencil)
packages/stencil/.stencil/
packages/stencil/www/
